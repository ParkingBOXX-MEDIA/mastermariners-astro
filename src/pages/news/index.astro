---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: "wooden-boat-regattas-2025",
    date: "2025-04-05",
    title: "Wooden Boat & Classic Yacht Regattas Worth Watching in 2025",
    summary: "From the Eggemoggin Reach to the Med, a round-up of the world's finest classic and traditional boat racing events this season.",
    tag: "Regattas",
    sponsored: false,
  },
];
---
<Layout title="Maritime News" description="Classic yacht regattas, wooden boat events, and traditional sailing news from around the world — curated for San Francisco Bay maritime enthusiasts.">

  <div class="hero-band">
    <h1>Maritime News & Events</h1>
    <p>Classic regattas, wooden boat gatherings, and traditional sailing news worldwide</p>
  </div>

  <main>
    <h1>Latest News</h1>
    <p>
      Coverage of classic yacht regattas, wooden boat shows, and traditional sailing events — with a focus on the West Coast and the global gaff-rig community.
    </p>

    <div class="post-list">
      {posts.map(post => (
        <div class="post-card">
          <div class="post-meta">
            <span class="post-tag">{post.tag}</span>
            {post.sponsored && <span class="tag sponsored-tag">Sponsored</span>}
            <span class="post-date">{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </div>
          <h2 class="post-title"><a href={`/news/${post.slug}`}>{post.title}</a></h2>
          <p class="post-summary">{post.summary}</p>
          <a href={`/news/${post.slug}`} class="read-more">Read more &rarr;</a>
        </div>
      ))}
    </div>

  </main>
</Layout>

<style>
  .post-list { display: flex; flex-direction: column; gap: 2rem; margin-top: 1.5rem; }
  .post-card {
    border: 1px solid var(--border);
    border-left: 4px solid var(--gold);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    background: var(--white);
  }
  .post-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; font-family: Arial, sans-serif; font-size: 0.82rem; }
  .post-tag { background: var(--navy); color: var(--white); padding: 0.15rem 0.5rem; border-radius: 3px; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .sponsored-tag { background: #8a6a00; color: #fff; padding: 0.15rem 0.5rem; border-radius: 3px; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .post-date { color: var(--muted); }
  .post-title { font-size: 1.2rem; margin: 0 0 0.5rem; border: none; padding: 0; }
  .post-title a { color: var(--navy); text-decoration: none; }
  .post-title a:hover { color: var(--gold); text-decoration: underline; }
  .post-summary { color: var(--text); margin-bottom: 0.75rem; }
  .read-more { font-family: Arial, sans-serif; font-size: 0.85rem; font-weight: bold; color: #1a5c9a; text-decoration: none; }
  .read-more:hover { text-decoration: underline; }
</style>
